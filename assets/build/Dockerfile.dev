# ---------------------------------------------
# STAGE 1: Build the application
# ---------------------------------------------
FROM python:3.13-slim

# Set working directory
WORKDIR /app

# Install build dependencies
# NOTE: Adding packages for development debugging and testing
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    python3-dev \
    git \
    curl \
    wget \
    bash \
    procps \
    findutils \
    grep \
    coreutils

# Copy project metadata + source so editable install can resolve packages
COPY pyproject.toml README.md /app/
COPY src /app/src

# Install dependencies (with dev extras) into a virtual environment to isolate them
RUN python -m venv /opt/venv && \
    /opt/venv/bin/pip install --no-cache-dir --upgrade pip && \
    /opt/venv/bin/pip install --no-cache-dir -e ".[dev]"

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/opt/venv/bin:$PATH"
